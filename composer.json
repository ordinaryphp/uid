{
  "name": "ordinary/uid",
  "description": "Universal Unique Identifier (OUID) implementation for OrdinaryPHP",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "OrdinaryPHP Contributors"
    }
  ],
  "require": {
    "php": "^8.5",
    "psr/clock": "^1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0"
  },
  "autoload": {
    "psr-4": {
      "Ordinary\\Uid\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ordinary\\Uid\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "preferred-install": "dist"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
